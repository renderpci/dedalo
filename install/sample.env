# ══════════════════════════════════════════════════════════════════════════════
#  DÉDALO v7 — sample.env  ·  every configurable setting, grouped by domain
# ══════════════════════════════════════════════════════════════════════════════
#
# Reference of every configuration setting this engine recognizes. This file
# is NOT loaded by Dédalo — copy the lines you need into ../private/.env and
# uncomment them. The installer drops a copy of this file next to your .env.
#
# FORMAT. KEY=value, one per line. No ${VAR} interpolation. Quote any value
# containing spaces or a #. List and map values are JSON — ["lg-eng","lg-spa"]
# or {"lg-eng":"English"}; simple lists also accept a comma list. Booleans are
# true/false.
#
# PRECEDENCE (low→high): catalog default → ../private/.env → the real process
# environment. There is no per-host overlay. After changing a value, restart
# the server.
#
# TAGS. [operator] a setting you may freely change · [secret] sensitive — set
# a real value, never commit it. Every line below is COMMENTED OUT at its
# default; uncomment only what you need to change. Lines that ship UNCOMMENTED
# carry a placeholder a real install must replace.
#
#  GENERATED from src/config/catalog/ — do not edit by hand.
#  Regenerate: bun run config:gen   (config_docs_tripwire fails if you forget)
# ══════════════════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════════════════════
#  [paths]  Main variables: Paths
# ══════════════════════════════════════════════════════════════════════════════

# The public domain or IP of this installation — the address other machines
# use to reach it. Dédalo does not need it to serve you; it needs it to tell
# someone else where it lives.
# [operator · string]  default: (empty)
#DEDALO_HOST=

# This parameter defines the internet protocol used to build absolute URLs. It
# is recommended to use the HTTPS protocol for an installation with SSL
# certification — it is not mandatory, but it ensures the connection is
# protected with encryption. Defaults to "http://" when unset.
# [operator · string]  default: http://
#DEDALO_PROTOCOL=http://

# ══════════════════════════════════════════════════════════════════════════════
#  [locale]  Locale
# ══════════════════════════════════════════════════════════════════════════════

# Defines the default order for the date input by users and to be showed in
# componentdate. By default Dédalo use dmy (European dates format).
# [operator · string]  default: dmy
#DEDALO_DATE_ORDER=dmy

# Defines the UI locale used to format and encode text. By default Dédalo uses
# UTF-8 encoding for Spanish (es-ES).
# [operator · string]  default: es-ES
#DEDALO_LOCALE=es-ES

# Used to defines the time zone of the project. It could be different of the
# server installation or the linux timezone. The time zone will be used to
# store the time stamp of the changes done by the users.
# [operator · string]  default: Europe/Madrid
#DEDALO_TIMEZONE=Europe/Madrid

# ══════════════════════════════════════════════════════════════════════════════
#  [entity]  Entity
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines the normalized id for the entity. The id of the
# entity could be used to create a locator to obtain information between
# Dédalo installations, the id will be added to the locator with the key:
# "entityid" when the locator point to external resource.
# [operator · int]  default: 0
#DEDALO_ENTITY_ID=0

# Defines the entity label, the real name of the entity. Due the entity
# definition is use to encrypt passwords or access to databases, sometimes you
# will need define the real name of the entity with characters such as 'ñ' or
# accents.
# [operator · string]  default: the value of `ENTITY`
DEDALO_ENTITY_LABEL=Dédalo install version

# This parameter defines the name of the entity proprietary of the Dédalo
# installation. Dédalo entity will be used to access to databases, to encrypt
# passwords or to publish data into the specific publication ontology and
# should NOT be changed after installation.
# [operator · string]  default: install
ENTITY=my_entity_name

# ══════════════════════════════════════════════════════════════════════════════
#  [langs]  Languages
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines the language will us Dédalo for the user interface.
# [operator · string]  default: lg-spa
#APPLICATION_LANG=lg-spa

# It defines the data language used by Dédalo to process and render textual
# information.
# [operator · string]  default: lg-spa
#DATA_LANG=lg-spa

# Defines whether the application language and data language selection remain
# synchronized.
# [operator · bool]  default: false
#DATA_LANG_SYNC=false

# This parameter defines the tld used by Dédalo to tag data without
# translation possibility.
# [operator · string]  default: lg-nolan
#DATA_NOLAN=lg-nolan

# This parameter defines the languages that Dédalo will use for the data and
# user interface. Dédalo is a true multi-language application, any text field
# can be defined as translatable and this configuration define the languages
# that the installation will use to store and translate text data. When the
# user select one of those languages Dédalo will change the data showed or the
# user interface, so it will render all data with this new language.
# [operator · object]  default: {"lg-eng":"English"}
DEDALO_APPLICATION_LANGS={"lg-eng":"English"}

# Defines the main language will used in the user interface.
# [operator · string]  default: lg-eng
DEDALO_APPLICATION_LANGS_DEFAULT=lg-eng

# Defines the main language will used by Dédalo to manage and process data.
# [operator · string]  default: lg-eng
DEDALO_DATA_LANG_DEFAULT=lg-eng

# It defines if the menu show or hide the data language selector.
# [operator · bool]  default: true
#DEDALO_DATA_LANG_SELECTOR=true

# This parameter defines the languages that Dédalo will use to publish data.
# [operator · array]  default: (unset)
#DEDALO_DIFFUSION_LANGS=

# This parameter defines the default language that the ontology will use as
# main language. The ontology (abstracted structure) is the definition of
# areas, sections, fields, connections between data and definition models. All
# terms used in the ontology can be translated to any language, but this main
# language defined here will be use as mandatory language, if Dédalo is
# configured in other language that is not defined in the ontology
# translations Dédalo will do a fall back to this main language, if these main
# language is not present, Dédalo will use any other language to show the
# interface and explanations.
# [operator · string]  default: lg-spa
#DEDALO_STRUCTURE_LANG=lg-spa

# This parameter defines the languages that will use for export and publish
# data.
# [operator · array]  default: ["lg-eng"]
PROJECTS_DEFAULT_LANGS=["lg-eng"]

# ══════════════════════════════════════════════════════════════════════════════
#  [defaults]  Default variables
# ══════════════════════════════════════════════════════════════════════════════

# !!! info "Renamed in v7 — was DEDALOPREFIXTIPOS" The old name did not
# describe the value: this is the set of ontology top-level domains active in
# the installation. The old spelling is retired — if it is still in your .env
# the server refuses to boot and names the line to change.
# [operator · array]  default: []
#ACTIVE_ONTOLOGY_TLDS=[]

# This parameter defines the default project that Dédalo will use to create
# new sections (records in the DDBB).
# [operator · int]  default: 1
#DEDALO_DEFAULT_PROJECT=1

# This parameter defines the section that has the projects information inside
# the ontology.
# [operator · string]  default: dd153
#DEDALO_FILTER_SECTION_TIPO_DEFAULT=dd153

# It defines the maximum rows that will loaded in the lists.
# [operator · int]  default: 10
#DEDALO_MAX_ROWS_PER_PAGE=10

# This parameter defines the ceiling applied to the number of rows a search
# coming FROM THE CLIENT may ask for.
# [operator · int]  default: 1000
#DEDALO_SEARCH_CLIENT_MAX_LIMIT=1000

# This parameter defines the section of the ontology that holds the USER
# records — the login names, the password hashes, the profile and the projects
# each user may reach.
# [operator · string]  default: dd128
#DEDALO_SECTION_USERS_TIPO=dd128

# It defines the section will loaded by default when the user login. The main
# section of the project that will used, normally will be a inventory or
# catalog section.
# [operator · string]  default: oh1
#MAIN_SECTION=oh1

# ══════════════════════════════════════════════════════════════════════════════
#  [media]  Media variables
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines the standards file types that will use to create
# alternative versions of the uploaded 3d files.
# [operator · array]  default: []
#DEDALO_3D_ALTERNATIVE_EXTENSIONS=[]

# This parameter defines the different qualities that can be used for store 3d
# files.
# [operator · array]  default: ["original","web"]
#DEDALO_3D_AR_QUALITY=["original","web"]

# This parameter defines the standard file type of 3d files.
# [operator · string]  default: glb
#DEDALO_3D_EXTENSION=glb

# This parameter defines the standards file type admitted for the 3d files.
# [operator · array]  default: ["glb","gltf","obj","fbx","dae","zip"]
#DEDALO_3D_EXTENSIONS_SUPPORTED=["glb","gltf","obj","fbx","dae","zip"]

# This parameter define the main directory for the 3d files.
# [operator · string]  default: /3d
#DEDALO_3D_FOLDER=/3d

# This parameter defines the default quality used for the 3d files.
# [operator · string]  default: web
#DEDALO_3D_QUALITY_DEFAULT=web

# This parameter defines the quality original for the 3d files.
# [operator · string]  default: original
#DEDALO_3D_QUALITY_ORIGINAL=original

# This parameter defines the standards file types that will use to create
# alternative versions of the uploaded audiovisual files.
# [operator · array]  default: []
#DEDALO_AV_ALTERNATIVE_EXTENSIONS=[]

# This parameter defines the different qualities that can be used for compress
# the audiovisual files.
# [operator · string]  default: ["original","1080","720","576","404","240","audio"]
#DEDALO_AV_AR_QUALITY=["original","1080","720","576","404","240","audio"]

# This parameter defines the standard file type of encapsulation for the
# audiovisual files.
# [operator · string]  default: mp4
#DEDALO_AV_EXTENSION=mp4

# This parameter defines the standards file type admitted for the audiovisual
# files.
# [operator · array]  default: ["mp4","wave","wav","aiff","aif","mp3","mov","avi","mpg","mpeg","vob","zip","flv"]
#DEDALO_AV_EXTENSIONS_SUPPORTED=["mp4","wave","wav","aiff","aif","mp3","mov","avi","mpg","mpeg","vob","zip","flv"]

# This parameter defines the path to the qt-faststart library in the server.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/qt-faststart`
#DEDALO_AV_FASTSTART_PATH=

# This parameter defines the path to the ffmpeg library in the server. ffmpeg
# will use to compress the audiovisual files.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/ffmpeg`
#DEDALO_AV_FFMPEG_PATH=

# This parameter defines the path to the ffprobe library in the server.
# ffprobe is used to analyze the audiovisual files and get his metadata.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/ffprobe`
#DEDALO_AV_FFPROBE_PATH=

# This parameter defines the main directory for the audiovisual files.
# [operator · string]  default: /av
#DEDALO_AV_FOLDER=/av

# This parameter defines the type of the image file used to create the
# posterframe of the audiovisual files.
# [operator · string]  default: jpg
#DEDALO_AV_POSTERFRAME_EXTENSION=jpg

# This parameter defines the default quality used for the audiovisual files.
# [operator · string]  default: 404
#DEDALO_AV_QUALITY_DEFAULT=404

# This parameter defines the quality original for the audiovisual files.
# [operator · string]  default: original
#DEDALO_AV_QUALITY_ORIGINAL=original

# This parameter defines the standard used to create the subtitles.
# [operator · string]  default: vtt
#DEDALO_AV_SUBTITLES_EXTENSION=vtt

# This parameter defines the directory where the external media binaries are
# installed.
# [operator · string]  default: `/opt/homebrew/bin` on macOS, `/usr/bin` elsewhere
#DEDALO_BINARY_BASE=

# This parameter defines the path to the file utility in the server, the
# program that reports the type of a file from its content.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/file`
#DEDALO_FILE_BIN_PATH=

# This parameter defines the tile maps provider to be used.
# [operator · string]  default: VARIOUS
#DEDALO_GEO_PROVIDER=VARIOUS

# This parameter defines the path to the ImageMagick identify program in the
# server. Dédalo uses it to read the attributes of an image file — dimensions,
# format, colorspace, orientation, transparency — before deciding how to
# compress it.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/identify`
#DEDALO_IDENTIFY_PATH=

# This parameter defines the standards file types that will use to create
# versions of the uploaded image files.
# [operator · array]  default: []
#DEDALO_IMAGE_ALTERNATIVE_EXTENSIONS=[]

# This parameter defines the different qualities that can be used for compress
# the image files.
# [operator · serialized array]  default: ["original","modified","100MB","25MB","6MB","1.5MB","thumb"]
#DEDALO_IMAGE_AR_QUALITY=["original","modified","100MB","25MB","6MB","1.5MB","thumb"]

# This parameter defines the standard file type of image files.
# [operator · string]  default: jpg
#DEDALO_IMAGE_EXTENSION=jpg

# This parameter defines the standards file type admitted for the image files.
# [operator · array]  default: ["jpg","jpeg","png","tif","tiff","bmp","psd","raw","webp","heic","avif"]
#DEDALO_IMAGE_EXTENSIONS_SUPPORTED=["jpg","jpeg","png","tif","tiff","bmp","psd","raw","webp","heic","avif"]

# This parameter defines the main directory for the image files.
# [operator · string]  default: /image
#DEDALO_IMAGE_FOLDER=/image

# This parameter defines the resolution in pixels per inch that will be used
# in the image compression to be apply when the images will be printed.
# [operator · int]  default: 150
#DEDALO_IMAGE_PRINT_DPI=150

# This parameter defines the default quality used for the image files.
# [operator · string]  default: 1.5MB
#DEDALO_IMAGE_QUALITY_DEFAULT=1.5MB

# This parameter defines the quality original for the image files.
# [operator · string]  default: original
#DEDALO_IMAGE_QUALITY_ORIGINAL=original

# This parameter defines the quality for the image files that has been
# retouched.
# [operator · string]  default: modified
#DEDALO_IMAGE_QUALITY_RETOUCHED=modified

# This parameter defines height size in pixels to the thumb images, it will be
# used to compress the images with the thumb quality (the smaller version to
# be used in lists).
# [operator · int]  default: 148
#DEDALO_IMAGE_THUMB_HEIGHT=148

# This parameter defines width size in pixels to the thumb images, it will be
# used to compress the images with the thumb quality (the smaller version to
# be used in lists).
# [operator · int]  default: 222
#DEDALO_IMAGE_THUMB_WIDTH=222

# This parameter defines the path to image magick library in the server (when
# image magick library is installed)
# [operator · string]  default: `<DEDALO_BINARY_BASE>/magick`
#DEDALO_MAGICK_PATH=

# This parameter defines the public address that media files are reachable at,
# and it is used to build ABSOLUTE media URLs where a relative one would be
# meaningless.
# [operator · string]  default: (unset)
#DEDALO_MEDIA_BASE_URL=

# This parameter defines the NAME of the media directory as it appears in the
# URL. Every media URL Dédalo builds is /dedalo/<DEDALOMEDIADIR>/ plus the
# file path.
# [operator · string]  default: media
#DEDALO_MEDIA_DIR=media

# This parameter defines how many media jobs Dédalo will run at the same time.
# [operator · int]  default: 3
#DEDALO_MEDIA_JOB_CONCURRENCY=3

# This parameter defines the directory holding the process files of the media
# jobs.
# [operator · string]  default: (unset)
#DEDALO_MEDIA_PROCESSES_DIR=

# This parameter defines the base every media URL served to the CLIENT is
# built on — the address the browser fetches images, video, PDFs and their
# derivatives from.
# [operator · string]  default: (unset)
#DEDALO_MEDIA_WEB_BASE=

# This parameter defines the standards file types that will use to create
# versions of the uploaded PDF files.
# [operator · array]  default: ["jpg"]
#DEDALO_PDF_ALTERNATIVE_EXTENSIONS=["jpg"]

# This parameter defines the different qualities that can be used for compress
# the PDF files.
# [operator · array]  default: ["original","web"]
#DEDALO_PDF_AR_QUALITY=["original","web"]

# This parameter defines the standard file type of pdf files.
# [operator · string]  default: pdf
#DEDALO_PDF_EXTENSION=pdf

# This parameter define the standards file type admitted for the pdf files.
# Dédalo will use this parameter to identify the file format of the original
# files uploaded by the users. Defaults to
# ["pdf","doc","pages","odt","ods","rtf","ppt"].
# [operator · array]  default: ["pdf","doc","pages","odt","ods","rtf","ppt"]
#DEDALO_PDF_EXTENSIONS_SUPPORTED=["pdf","doc","pages","odt","ods","rtf","ppt"]

# This parameter defines the main directory for the pdf files.
# [operator · int]  default: /pdf
#DEDALO_PDF_FOLDER=/pdf

# This parameter defines the default quality used for the PDF files.
# [operator · string]  default: web
#DEDALO_PDF_QUALITY_DEFAULT=web

# This parameter defines the quality original for the pdf files.
# [operator · string]  default: original
#DEDALO_PDF_QUALITY_ORIGINAL=original

# This parameter defines the path to the pdfinfo program in the server,
# usually shipped with Poppler. Dédalo uses it to read the metadata of the
# uploaded PDF files — the number of pages and the creation date that feeds
# the automatic date components.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/pdfinfo`
#DEDALO_PDFINFO_PATH=

# This parameter defines the path to the pdftohtml program in the server,
# usually shipped with Poppler. The PDF extractor tool uses it to pull the
# content of a PDF out as formatted HTML, keeping the layout of the page; the
# plain-text alternative is PDFAUTOMATICTRANSCRIPTIONENGINE, and the user
# chooses between them in the tool.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/pdftohtml`
#DEDALO_PDFTOHTML_PATH=

# This parameter defines the thumb quality definition that can be used for
# compress the media files.
# [operator · string]  default: thumb
#DEDALO_QUALITY_THUMB=thumb

# This parameter defines the path to the subtitles directory.
# [operator · string]  default: /subtitles
#DEDALO_SUBTITLES_FOLDER=/subtitles

# This parameter defines the standards file types that will use to create
# alternative versions of the uploaded svg files.
# [operator · array]  default: []
#DEDALO_SVG_ALTERNATIVE_EXTENSIONS=[]

# This parameter defines the different qualities that can be used transformed
# svg files.
# [operator · array]  default: ["original","web"]
#DEDALO_SVG_AR_QUALITY=["original","web"]

# This parameter defines the standard file type of svg files.
# [operator · string]  default: svg
#DEDALO_SVG_EXTENSION=svg

# This parameter defines the standards file type admitted for the svg files.
# [operator · array]  default: ["svg"]
#DEDALO_SVG_EXTENSIONS_SUPPORTED=["svg"]

# This parameter defines the main directory for the svg files.
# [operator · string]  default: /svg
#DEDALO_SVG_FOLDER=/svg

# This parameter defines the default quality used for the SVG files.
# [operator · string]  default: web
#DEDALO_SVG_QUALITY_DEFAULT=web

# This parameter defines the quality original for the svg files.
# [operator · string]  default: original
#DEDALO_SVG_QUALITY_ORIGINAL=original

# This parameter defines the standard file type of thumb files.
# [operator · string]  default: jpg
#DEDALO_THUMB_EXTENSION=jpg

# This parameter defines the largest file, in BYTES, that Dédalo will accept
# in an upload.
# [operator · int]  default: 2147483648
#DEDALO_UPLOAD_MAX_SIZE_BYTES=2147483648

# Defines the size at which files are split into chunks for upload.
# [operator · int || false]  default: 4
#DEDALO_UPLOAD_SERVICE_CHUNK_FILES=4

# Defines the maximum number of simultaneous HTTP requests that can be open to
# the server when uploading a file in chunks.
# [operator · int || false]  default: 50
#DEDALO_UPLOAD_SERVICE_MAX_CONCURRENT=50

# This parameter defines the staging directory where an upload is assembled,
# RELATIVE to the media root (MEDIAPATH).
# [operator · string]  default: upload/service_upload/tmp
#DEDALO_UPLOAD_TMP_SUBDIR=upload/service_upload/tmp

# You normally leave this unset. Media files are served by the WEB SERVER,
# which enforces the access rules Dédalo generates for it. But Dédalo can also
# serve them itself, straight from the media root — with no per-record access
# control at all. That fallback exists for the one setup that has no web
# server in the request path: a developer running the engine on its local TCP
# port.
# [operator · bool]  default: (unset)
#MEDIA_DEV_ROUTE_ENABLED=

# This parameter defines the root media directory in the directory tree.
# [operator · string]  default: `<install dir>/media` — auto-derived; set only to relocate the media tree
#MEDIA_PATH=

# This parameter defines the path to the library, usually xpdf (pdftotext), to
# be used for process the pdf to extract the information, this library will be
# used get the text fo the pdf files and store in the componenttextarea. The
# text will be use to search inside the pdf information.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/pdftotext`
#PDF_AUTOMATIC_TRANSCRIPTION_ENGINE=

# This parameter defines the path to the library, usually ocrmypdf that will
# be used for OCR processing of the pdf uploaded files. Optical Character
# Recognition or OCR is a technology that converts images of typed or
# handwritten text, such as in a scanned document, into computer text that can
# be selected, searched and copied.
# [operator · string]  default: `<DEDALO_BINARY_BASE>/ocrmypdf`
#PDF_OCR_ENGINE=

# ══════════════════════════════════════════════════════════════════════════════
#  [menu]  Menu variables
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines the areas that are removed from the installation.
# [operator · array]  default: ["dd137","rsc1","hierarchy20"]
#AREAS_DENY=["dd137","rsc1","hierarchy20"]

# This parameter defines the tipos to be skipped from the menu.
# [operator · array]  default: ["dd349","dd355","numisdata1","tch188"]
#MENU_SKIP_TIPOS=["dd349","dd355","numisdata1","tch188"]

# ══════════════════════════════════════════════════════════════════════════════
#  [security]  Security variables
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines components to be excluded.
# [operator · array]  default: []
#DEDALO_AR_EXCLUDE_COMPONENTS=[]

# This parameter defines if Dédalo will lock / unlock components to avoid
# replacement data when more than one user edit the same component or Dédalo
# do not manage the user edition unlocking all components. By default Dédalo
# do not manage the editions (option false).
# [operator · bool]  default: true
#DEDALO_LOCK_COMPONENTS=true

# This parameter defines if the directory of the media files (av, images, pdf,
# subtitles, ...) will be protected and controlled for undesired/external
# access. The full documentation, with the architecture, use cases, web server
# configuration and examples, is in Media protection (media file access
# control).
# [operator · false | string]  default: (empty)
#DEDALO_MEDIA_ACCESS_MODE=

# The quality folders an anonymous visitor may read when the record is
# published (rule B). A JSON array, or a comma-separated list. Leave it unset
# to derive the delivery-grade folders from this installation's own quality
# catalog — av/404, av/posterframe, av/subtitles, image/1.5MB, image/thumb,
# pdf/web, svg/web, 3d/web.
# [operator · string[]]  default: (unset)
#DEDALO_MEDIA_PUBLIC_QUALITIES=

# This parameter defines if Dédalo will notify to the user than other users
# are editing the same field in the same section when the user try to edit the
# field.
# [operator · bool]  default: false
#DEDALO_NOTIFICATIONS=false

# The legacy boolean is kept for back-compat: true behaves as
# DEDALOMEDIAACCESSMODE='private' when the new constant is not defined.
# [operator · bool]  default: false
#DEDALO_PROTECT_MEDIA_FILES=false

# The lifetime, in minutes, that the upload service announces for a queued
# upload session. The engine reports it with the rest of the system
# information, and the upload panel displays it, so a user knows how long
# files that were uploaded but not yet saved into a record remain available in
# the temporary upload directory.
# [operator · int]  default: 180
#DEDALO_SESSION_CACHE_EXPIRE=180

# The second dimension of the login throttle: how many failed logins one user
# name may accumulate inside LOGINATTEMPTWINDOW from any address at all,
# before that account is locked for LOGINLOCKOUTSECONDS. It is what stops an
# attacker who rotates addresses (every new address gets a fresh per-address
# bucket, but they all share this one).
# [operator · int]  default: 50
#LOGIN_ACCOUNT_MAX_ATTEMPTS=50

# The sliding window, in seconds, over which failed logins are counted for
# both throttle limits (LOGINMAXATTEMPTS and LOGINACCOUNTMAXATTEMPTS). A
# failure older than the window no longer counts against anyone, and is
# deleted from the store once it can no longer influence a decision.
# [operator · int]  default: 900
#LOGIN_ATTEMPT_WINDOW=900

# How long, in seconds, a login stays refused once a throttle limit has been
# reached. The lock lifts this long after the most recent counted failure; a
# successful login clears the counters immediately, so a user who finally
# remembers the password is not kept waiting.
# [operator · int]  default: 900
#LOGIN_LOCKOUT_SECONDS=900

# How many failed logins the same user name may accumulate from the same
# client address inside LOGINATTEMPTWINDOW before further attempts are refused
# for LOGINLOCKOUTSECONDS. A successful login clears the counter at once.
# [operator · int]  default: 10
#LOGIN_MAX_ATTEMPTS=10

# Raw Apache rewrite directives appended to the generated .htaccess
# immediately before the final deny rule. You own their syntax; Dédalo only
# places them.
# [operator · string[]]  default: []
#MEDIA_HTACCESS_ADDONS=[]

# Each user's permission table — the grants their profile gives them over
# sections and components — is resolved from the database once and then kept
# in memory. Saving a profile or changing a user's profile drops the cached
# table immediately, so a grant change is normally visible on the next
# request.
# [operator · int]  default: 300
#PERMISSIONS_CACHE_TTL_SECONDS=300

# The hard ceiling, in seconds, on a session's life counted from the moment it
# was created — regardless of how active it has been. It exists because an
# idle limit alone (SESSIONTTLSECONDS) never expires a session that is used at
# least once per window: a stolen cookie would live forever.
# [operator · int]  default: 2592000
#SESSION_ABSOLUTE_TTL_SECONDS=2592000

# Marks the session cookie Secure, so the browser only ever sends it back over
# HTTPS (the media access cookie carries the same posture). It is true by
# default and it should stay true on anything reachable over a network: a
# session cookie that travels once in clear text is a session an eavesdropper
# can replay.
# [operator · bool]  default: true
#SESSION_COOKIE_SECURE=true

# How long, in seconds, a session survives without being used. Every
# authenticated request refreshes it; a session left untouched for longer than
# this is destroyed and the user must log in again.
# [operator · int]  default: 43200
#SESSION_TTL_SECONDS=43200

# ══════════════════════════════════════════════════════════════════════════════
#  [server]  Server and runtime
# ══════════════════════════════════════════════════════════════════════════════

# A code update replaces the installation tree and then exits the server
# process, so that it comes back up running the new code. That only works if
# something restarts it. To avoid taking the server down for good, the update
# refuses to run unless it can see a supervisor.
# [operator · bool]  default: (unset)
#DEDALO_SUPERVISED=

# How many seconds a request may stay idle before the engine drops the
# connection. It applies to both listeners, and it is clamped to the range
# 1–255.
# [operator · int]  default: 255
#SERVER_IDLE_TIMEOUT_S=255

# The ceiling, in bytes, on the body of any single request the engine accepts.
# Every body is buffered whole in a long-lived process, so an unbounded one is
# a memory-exhaustion hazard — this is the cap that bounds it.
# [operator · int]  default: 268435456
#SERVER_MAX_BODY_BYTES=268435456

# When the server is asked to stop — a service restart, a deploy, a Ctrl-C —
# it stops accepting new connections and then drains the requests already in
# flight for up to this many milliseconds before it closes the database pool,
# removes the socket file and exits. Users mid-save are not cut off by a
# routine restart.
# [operator · int]  default: 10000
#SERVER_SHUTDOWN_GRACE_MS=10000

# When set, the engine opens an additional plain-HTTP listener on this port,
# on top of the unix socket, and the client is reachable at
# http://localhost:<port>/dedalo/core/page/. It exists because a browser
# cannot talk to a unix socket directly, so a developer would otherwise need a
# web server in front of every local checkout.
# [operator · int]  default: (unset)
#SERVER_TCP_PORT=

# The unix socket the engine listens on. In production this is the only
# listener: the web server owns TCP and TLS, serves the client files and the
# media, and forwards the API and the dynamic routes to this socket.
# [operator · string]  default: /tmp/dedalo_ts.sock
#SERVER_UNIX_SOCKET=/tmp/dedalo_ts.sock

# How many reverse proxies stand between the internet and the engine. Each one
# appends the address it received the request from to the X-Forwarded-For
# header, so the genuine client address is the entry this many positions from
# the right. Everything further to the left was supplied by the caller and can
# be forged freely.
# [operator · int]  default: 1
#TRUSTED_PROXY_HOPS=1

# ══════════════════════════════════════════════════════════════════════════════
#  [mailer]  Outbound email and password recovery
# Dédalo relays outbound email (password-recovery codes) through an existing
# mailbox over SMTP — it never runs its own mail server. Leaving
# `DEDALO_SMTP_HOST` empty disables sending entirely, which also disables the
# login screen's password-recovery emails.
# ══════════════════════════════════════════════════════════════════════════════

# The hostname of the SMTP server Dédalo relays outbound email through
# (recovery codes, notifications). Leaving it empty disables the mailer
# entirely — features that need email (the login screen's password recovery)
# will silently skip sending.
# [operator · string]  default: (empty)
#DEDALO_SMTP_HOST=

# The TCP port of the SMTP server. The default 587 is the submission port used
# with STARTTLS; use 465 with DEDALOSMTPSECURE='ssl' for implicit TLS.
# [operator · int]  default: 587
#DEDALO_SMTP_PORT=587

# How the SMTP connection is encrypted:
# [operator · string]  default: tls
#DEDALO_SMTP_SECURE=tls

# The SMTP AUTH username (usually the mailbox login). Leave it empty for a
# relay that accepts unauthenticated mail (e.g. a local MTA).
# [operator · string]  default: (empty)
#DEDALO_SMTP_USER=

# The SMTP AUTH password for DEDALOSMTPUSER. Ignored when the user is empty.
# [secret · string]  default: (empty)
#DEDALO_SMTP_PASS=

# The envelope/header From address of outbound mail. It must be an address the
# relay is allowed to send as (most providers refuse arbitrary senders). When
# empty, DEDALOSMTPUSER is used; if both are empty the mailer refuses to send.
# [operator · string]  default: (empty)
#DEDALO_SMTP_FROM=

# An optional display name shown next to the From address.
# [operator · string]  default: (empty)
#DEDALO_SMTP_FROM_NAME=

# How long, in seconds, an emailed password-recovery code stays valid. The
# code is single-use and its short life is part of what makes the 8-digit
# space safe, so keep this small. Default 600 (10 minutes).
# [operator · int]  default: 600
#DEDALO_PWRESET_CODE_TTL=600

# How many wrong guesses are allowed against a single issued recovery code
# before it is invalidated and the user must request a new one. Together with
# the short DEDALOPWRESETCODETTL this caps brute-force odds against the
# 8-digit code at a few in a hundred million. Default 5.
# [operator · int]  default: 5
#DEDALO_PWRESET_MAX_ATTEMPTS=5

# ══════════════════════════════════════════════════════════════════════════════
#  [ops]  Logs, backups and diagnostics
# ══════════════════════════════════════════════════════════════════════════════

# With true, the engine writes one JSON line per API request to its standard
# output: timestamp, request id, user id, the API class and action that was
# called, the response status and the duration in milliseconds. A service
# manager captures it with the rest of the service log, so it can be filtered
# and parsed with the usual tools.
# [operator · bool]  default: false
#DEDALO_ACCESS_LOG=false

# Where the database dumps produced by the maintenance backup tool (and by a
# scheduled nightly backup job) are written. Unset, they go to backups/db
# inside the private directory, next to the configuration file and the session
# store.
# [operator · string]  default: (unset)
#DEDALO_BACKUP_DIR=

# This parameter defines the directory a code update stages the previous tree
# into before swapping in a new release, so a failed update can be rolled
# back. Keep it outside the served tree for security. Defaults to
# <install>/../backups/code. This is distinct from DEDALOBACKUPDIR, which sets
# the directory for database backups (see Database connection).
# [operator · string]  default: (unset)
#DEDALO_BACKUP_PATH=

# This parameter defines the time lapse between backup copies in hours. Dédalo
# check in every user login if the last backup exceed this time lapse, in
# affirmative case, it will create new one.
# [operator · int]  default: 8
#DEDALO_BACKUP_TIME_RANGE=8

# When a request fails unexpectedly, the client is answered with a generic
# message and a request id, while the exception text stays on the server,
# logged under that same id. This is deliberate: the raw text of an error can
# carry query fragments, filesystem paths and internal identifiers, and the
# request id is what lets you find the full story in the log without handing
# any of it to the caller.
# [operator · bool]  default: (unset)
#DEDALO_DEBUG_API_ERRORS=

# Marks this installation as a development server. With true, logged-in users
# get the debug and developer surfaces in the interface (the extra inspection
# panels), the client is told it is talking to a development server so it
# takes the no-cache path instead of the offline service-worker one, and the
# readable, non-minified versions of the client libraries are served. The
# configuration widget in the maintenance area reports the mode it resolved,
# so you can always check what a running server thinks it is.
# [operator · bool]  default: false
#DEDALO_DEV_MODE=false

# Any API request that takes longer than this, in milliseconds, is warn-logged
# with its duration, the API call, the request id and the user — and counted,
# so the count also shows up in the server counters. This happens whether or
# not the access log is on.
# [operator · int]  default: 5000
#DEDALO_SLOW_REQUEST_MS=5000

# Defines the directory path to store the update log.
# [operator · string]  default: (unset)
#UPDATE_LOG_FILE=

# ══════════════════════════════════════════════════════════════════════════════
#  [error_report]  Error reporting
# ══════════════════════════════════════════════════════════════════════════════

# Only meaningful on the master installation (the one that receives reports).
# A comma-separated list of the IP addresses allowed to reach the intake; a
# report from any other address is refused. The shorthand loopback accepts the
# local machine.
# [operator · string]  default: (unset)
#DEDALO_ERROR_REPORT_ALLOWED_IPS=

# The JSON API endpoint of the master installation this Dédalo sends its error
# reports to. Setting it is what enables reporting: with a master URL
# configured, global administrators get a report button on every page, from
# which they can describe a problem and send it — together with the page
# context and any JavaScript errors captured since the page loaded — to the
# maintainers. Nothing ever leaves the machine without that explicit click.
# [operator · string]  default: (unset)
#DEDALO_ERROR_REPORT_MASTER_URL=

# Set to true only on the designated master installation — the one other
# Dédalos point at with their master URL. It opens the intake endpoint that
# stores the incoming reports, and it turns on the Error reports widget of the
# maintenance dashboard, where an administrator can browse what has arrived.
# [operator · bool]  default: false
#DEDALO_ERROR_REPORT_RECEIVER=false

# Only meaningful on the master installation. Received reports older than this
# many days are pruned. Default 90; 0 keeps them forever.
# [operator · int]  default: 90
#DEDALO_ERROR_REPORT_RETENTION_DAYS=90

# How long (in milliseconds) this server waits for the master installation to
# accept a relayed report before giving up. Default 10000 (ten seconds),
# minimum 1000.
# [operator · int]  default: 10000
#DEDALO_ERROR_REPORT_TIMEOUT_MS=10000

# An optional shared secret sent with every relayed report and checked by the
# master installation, which rejects a report that does not carry the matching
# value. It is a spam filter, not authentication: the sending server, not the
# browser, adds it.
# [secret · string]  default: (unset)
#DEDALO_ERROR_REPORT_TOKEN=

# ══════════════════════════════════════════════════════════════════════════════
#  [ai]  AI assistant, agent and semantic search
# ══════════════════════════════════════════════════════════════════════════════

# This parameter names the model the assistant uses when no model catalog is
# declared. It only matters in the zero-configuration case: with
# DEDALOAGENTMODELS unset and an ANTHROPICAPIKEY present, Dédalo builds an
# implicit one-model catalog and this is the model id it asks for. As soon as
# you declare an explicit catalog, this parameter is ignored — each catalog
# entry carries its own model id.
# [operator · string]  default: claude-opus-4-8
#AGENT_MODEL=claude-opus-4-8

# The credential the assistant sends to Anthropic. It is used by every catalog
# entry whose provider is anthropic and does not name its own key variable,
# and it is what makes the implicit (zero-configuration) catalog exist at all:
# with no key and no DEDALOAGENTMODELS, the assistant has no models and stays
# disabled.
# [secret · string]  default: (unset)
#ANTHROPIC_API_KEY=

# This parameter decides whether a conversation held with an external model
# (one whose catalog egress class is external — any model whose API call
# leaves your server) may receive the content of your records at all. It is
# the privacy switch for institutions whose data may not leave the building.
# [operator · bool]  default: false
#DEDALO_AGENT_ALLOW_EXTERNAL_PROVIDER_DEFAULT=false

# This parameter exposes the assistant's write tools and the change-plan flow.
# With the default false the assistant is strictly read-only: the write tools
# are not even listed to the model, and a call to one is refused.
# [operator · bool]  default: false
#DEDALO_AGENT_ALLOW_WRITE=false

# The master switch for the assistant inside the Dédalo client: the chat
# panel, the model list, and the streaming answer. With the default false
# every assistant request is refused like an unknown action, and the panel
# reports the feature as disabled — the rest of the application is unaffected.
# [operator · bool]  default: false
#DEDALO_AGENT_HTTP_ENABLED=false

# The maximum number of tokens the assistant may produce in a single model
# turn. It caps the length of one answer (and the cost of one runaway
# generation); it does not cap the conversation, which may take several turns.
# [operator · int]  default: 16000
#DEDALO_AGENT_MAX_TOKENS=16000

# The list of models the assistant may use — the one place a deployment
# declares what the user can pick from, and where each model's answers travel.
# It is a JSON array; each entry takes id, label (what the user sees),
# provider (anthropic or openaicompatible), model (the provider's own model
# id), and optionally endpoint, apikeyenv (the NAME of another variable
# holding the key — never the key itself), egress (local or external), vision,
# maxtokens and timeouts. The first entry is the default choice.
# [operator · array of objects (JSON)]  default: (unset)
#DEDALO_AGENT_MODELS=

# Free text appended to the assistant's built-in instructions, so it knows
# where it is working. Use it for the facts a model cannot guess: what the
# institution holds, which language its labels are in, which collection is the
# important one.
# [operator · string]  default: (unset)
#DEDALO_AGENT_SYSTEM_PROMPT_APPEND=

# A comma-separated list of section tipos the assistant's change plans may
# touch. It narrows write mode to the part of the repository you are willing
# to let a model propose edits in — a cataloguing section, say, and nothing
# else. A plan naming any other section is refused before it reaches the
# database.
# [operator · string[]]  default: (unset)
#DEDALO_AGENT_WRITE_SECTIONS=

# Exposes the write tools in the stand-alone tool server — the separate
# process that offers Dédalo's tools to an external AI client over a local
# pipe. With the default false that server registers read tools only, and a
# write call is refused as read-only.
# [operator · bool]  default: false
#DEDALO_MCP_ALLOW_WRITE=false

# The one directory from which the stand-alone tool server may ingest a media
# file by path. Unset by default, and unset means the whole path-based branch
# is disabled: a tool call that names a file path is refused, and media can
# only be uploaded as inline data.
# [operator · string]  default: (unset)
#DEDALO_MCP_MEDIA_IMPORT_DIR=

# The largest media file, in bytes, the stand-alone tool server will accept in
# one upload tool call — whether it arrives as inline data or from the import
# directory. Anything larger is refused with a "too large" message.
# [operator · int]  default: 10485760
#DEDALO_MCP_MEDIA_MAX_BYTES=10485760

# The Dédalo user the stand-alone tool server acts as. That server has no
# login: it resolves this one identity at startup and keeps it for the whole
# process lifetime — every tool call it serves is authorized against this
# user's permissions and record scope, exactly as if that person had done it
# in the client. There is no tool to change identity mid-flight.
# [operator · int]  default: (unset)
#DEDALO_MCP_USER_ID=

# A comma-separated list of section tipos the stand-alone tool server's write
# tools may target. A write call addressing any other section is refused
# before the engine is reached.
# [operator · string[]]  default: (unset)
#DEDALO_MCP_WRITE_SECTIONS=

# How many text fragments Dédalo sends to the embedding service in one request
# while indexing. It is a throughput knob for the indexer, invisible to end
# users.
# [operator · int]  default: 32
#DEDALO_RAG_BATCH_SIZE=32

# How Dédalo cuts a long text into the fragments it indexes for semantic
# search. Two strategies exist:
# [operator · string]  default: structural_semantic
#DEDALO_RAG_CHUNK_STRATEGY=structural_semantic

# The largest fragment, in tokens, the chunker will emit. Bigger fragments
# carry more context into an answer but blur the match — the embedding of a
# long passage is an average of everything in it, so a precise question
# retrieves it less sharply. Smaller fragments match precisely but may arrive
# without the sentence that explains them.
# [operator · int]  default: 450
#DEDALO_RAG_CHUNK_TOKENS=450

# The floor, in tokens, below which the chunker will not leave a fragment
# standing on its own: a shorter one is merged into its neighbour. Without a
# floor, a heading or a one-line field becomes a fragment of its own, and such
# a fragment matches many questions weakly and none of them well.
# [operator · int]  default: 120
#DEDALO_RAG_CHUNK_MIN_TOKENS=120

# Under the structuralsemantic strategy, how different two consecutive
# passages must be before the chunker cuts between them. It is a similarity
# threshold between 0 and 1: the cut is made when similarity falls below it.
# [operator · float]  default: 0.92
#DEDALO_RAG_SEMANTIC_BREAKPOINT_THRESHOLD=0.92

# The host of the vector database. Set it only when the semantic index lives
# on a different database server than the catalogue: when unset (the default),
# Dédalo reuses the main database's host, and the same goes for
# DEDALORAGDBPORTCONN, DEDALORAGDBUSERNAMECONN and DEDALORAGDBPASSWORDCONN.
# The typical installation sets none of them.
# [operator · string]  default: (unset)
#DEDALO_RAG_DB_HOSTNAME_CONN=

# The name of the database that holds the semantic index — the vectors and the
# indexed text fragments. It is deliberately separate from the catalogue
# database: nothing in it is irreplaceable, since the whole index can be
# rebuilt from the records at any time.
# [operator · string]  default: (unset)
#DEDALO_RAG_DB_NAME=

# The password used to connect to the vector database. Needed only when the
# semantic index lives on a different database server (or under a different
# role) than the catalogue: unset, Dédalo reuses the main database password.
# [secret · string]  default: (unset)
#DEDALO_RAG_DB_PASSWORD_CONN=

# The port of the vector database server. Set it only when the semantic index
# lives on a different server, or on a non-standard port; unset (the default),
# Dédalo reuses the main database's port. A value that is not a positive
# number is ignored and the main database's port is used.
# [operator · int]  default: (unset)
#DEDALO_RAG_DB_PORT_CONN=

# The Unix socket directory of the vector database, for a local connection
# that does not go through the network stack. When set it wins over the host
# and port settings.
# [operator · string]  default: (empty)
#DEDALO_RAG_DB_SOCKET_CONN=

# The role used to connect to the vector database. Set it only when the
# semantic index lives on a different database server, or is owned by a
# different role, than the catalogue; unset (the default), Dédalo reuses the
# main database user.
# [operator · string]  default: (unset)
#DEDALO_RAG_DB_USERNAME_CONN=

# The base URL of the embedding service that turns text into vectors. It is
# required for real semantic search: with DEDALORAGEMBEDDINGPROVIDER=sidecar
# but no endpoint, Dédalo silently keeps the built-in development embedder,
# whose results are reproducible but not meaningful.
# [operator · string]  default: (empty)
#DEDALO_RAG_EMBEDDING_ENDPOINT=

# The model name Dédalo asks the embedding service for. It is also the
# partition key of the semantic index: vectors are stored per model, so two
# models never contaminate each other's results.
# [operator · string]  default: bge-m3
#DEDALO_RAG_EMBEDDING_MODEL=bge-m3

# Which embedder produces the vectors behind semantic search. Set it to
# sidecar to use a real embedding service — and then
# DEDALORAGEMBEDDINGENDPOINT must be set too, or Dédalo falls back to the
# built-in one.
# [operator · string]  default: (empty)
#DEDALO_RAG_EMBEDDING_PROVIDER=

# The master switch for semantic search: the vector index, the indexing that
# follows a save, and the search and question-answering actions built on them.
# With the default false the subsystem costs nothing — no indexing work is
# queued when a record is saved, and every semantic-search request is
# declined.
# [operator · bool]  default: false
#DEDALO_RAG_ENABLED=false

# A comma-separated list of section tipos whose content must never reach a
# model hosted outside your server — the never-egress list. It is the one
# place an institution names its protected material (an oral-history
# collection, a donor file), and it is honoured by both AI surfaces: the
# assistant's conversations and the semantic question-answering. One
# classification, applied twice.
# [operator · string[]]  default: (unset)
#DEDALO_RAG_EXTERNAL_PROVIDER_FORBIDDEN_SECTIONS=

# How long, in seconds, Dédalo waits for the embedding service to answer one
# batch before giving up on it. A timed-out batch is a retryable indexing
# failure, never a partial write.
# [operator · int]  default: 30
#DEDALO_RAG_PROVIDER_TIMEOUT=30

# A tuning constant of the hybrid ranking. A semantic search runs two searches
# — one on meaning (vectors), one on words (full text) — and merges the two
# rankings by position rather than by score, since the scores are not
# comparable. This value damps how much the very top positions dominate that
# merge.
# [operator · int]  default: 60
#DEDALO_RAG_RRF_K=60

# The compatibility spelling of the vector-database name, still honoured so
# that an installation configured before DEDALORAGDBNAME existed keeps working
# untouched.
# [operator · string]  default: dedalo7_rag
#RAG_DB_NAME=dedalo7_rag

# ══════════════════════════════════════════════════════════════════════════════
#  [tools]  Tools
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines extra directories where Dédalo will look for tools,
# besides the tools/ directory of the installation itself.
# [operator · array of objects]  default: (unset)
#DEDALO_ADDITIONAL_TOOLS=

# This parameter defines the directory holding the transform definition files
# — the JSON declarations that drive the move maintenance widgets (move a
# tipo, move a locator, move data into a portal or into a table, move a
# language).
# [operator · string]  default: `<install dir>/install/transform_definition_files`
#DEDALO_TRANSFORM_DEFINITIONS_DIR=

# This parameter defines whether the "Register tools" maintenance widget may
# WRITE to the tools registry, or only report what it would write.
# [operator · bool]  default: false
#TOOLS_ENABLE_REGISTRY_IMPORT=false

# This parameter defined how long, in milliseconds, the server kept the tools
# registry in memory before reading it from the database again.
# [operator · int]  default: 60000
#TOOLS_REGISTRY_CACHE_TTL_MS=60000

# ══════════════════════════════════════════════════════════════════════════════
#  [sitebuilder]  Site builder
# ══════════════════════════════════════════════════════════════════════════════

# This parameter is the base URL of the Site Builder service — the standalone
# daemon that lets your users build their own public websites over the
# published data by talking to a coding agent.
# [operator · string]  default: (unset)
#DEDALO_SITE_BUILDER_URL=

# The shared bearer token the engine presents to the Site Builder daemon on
# every call. It MUST equal the daemon's own SERVICETOKEN (the daemon's
# installer generates one and prints it).
# [secret · string]  default: (unset)
#DEDALO_SITE_BUILDER_TOKEN=

# How long, in milliseconds, the engine waits for a JSON response from the
# Site Builder daemon before giving up and reporting the service unreachable.
# It bounds the ordinary control calls (list sites, start a session, trigger a
# build); the live event stream a session produces is NOT subject to it — a
# streamed turn may run for many minutes.
# [operator · int]  default: 10000
#DEDALO_SITE_BUILDER_TIMEOUT_MS=10000

# ══════════════════════════════════════════════════════════════════════════════
#  [install]  Install
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines which addresses may reach the install wizard.
# [operator · string]  default: (unset)
#DEDALO_INSTALL_ALLOWED_IPS=

# This parameter defines the directory the installer WRITES to — the
# configuration file it persists, the state file, the sessions and the
# backups.
# [operator · string]  default: (unset)
#DEDALO_INSTALL_PRIVATE_DIR=

# ══════════════════════════════════════════════════════════════════════════════
#  [maintenance]  Maintenance variables
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines the code servers this install offers releases from.
# By default the server defines the official Dédalo code server, but you can
# include other mirror servers by adding entries to the array. Each entry is a
# JSON object with name, url and code.
# [operator · array]  default: (unset)
#CODE_SERVERS=

# This parameter defines the path to the code files in the server. Default
# location in root path /code. Code files are organize in version directories
# with major / minor / versiondedalo.zip as:
# ./dedalo/code/6/6.4/6.4.1dedalo.zip
# [operator · string]  default: (unset)
#DEDALO_CODE_FILES_DIR=

# This parameter defines the path to git directory in the server. It use to
# build the version with for specific version. GIT directory is a valid git
# server than can provide the build version. This parameter is not necessary
# if the server will be only a mirror from official files.
# [operator · string]  default: (unset)
#DEDALO_CODE_SERVER_GIT_DIR=

# This parameter defines the path to the local directory to save the new code
# downloaded from the master server repository.
# [operator · string]  default: (unset)
#DEDALO_SOURCE_VERSION_LOCAL_DIR=

# This parameter defines if the server can provide code to other Dédalo
# servers. By default no Dédalo server provides code, but it is possible to
# set one up as a mirror server that provides code versions. To enable it,
# also set DEDALOCODEFILESDIR — the URL other servers fetch from is derived
# automatically.
# [operator · bool]  default: false
#IS_A_CODE_SERVER=false

# It defines if the installation server can provide his ontology files to
# other Dédalo servers.
# [operator · bool]  default: false
#IS_AN_ONTOLOGY_SERVER=false

# This parameter defines the directory to input/output the ontology files in
# the server. Ontology files can be created by master ontology servers or
# downloaded from an external provider such as the official master Dédalo
# server. Defaults to install/import/ontology inside the install tree.
# [operator · string]  default: `<install dir>/install/import/ontology`
#ONTOLOGY_DATA_IO_DIR=

# It defines the valid code for clients to validate to get ontology files.
# [operator · string]  default: (unset)
#ONTOLOGY_SERVER_CODE=

# This parameter defines the ontology master servers to get the ontology
# updates. The servers could be:
# [operator · array of objects]  default: (unset)
#ONTOLOGY_SERVERS=

# This parameter defines if the installation will be updated his ontology
# using the master server versions.
# [operator · bool]  default: (unset)
#STRUCTURE_FROM_SERVER=

# Enables the built-in, self-hosted IP to Country resolution used in section
# Activity to show the source country flag from an IP address.
# [operator · bool]  default: true
#DEDALO_GEOIP_ENABLED=true

# Directory where the local IP to Country database file is downloaded and
# cached. Defaults to geoip inside the private directory (outside the web
# root).
# [operator · string]  default: `<private dir>/geoip`
#DEDALO_GEOIP_DIR=

# When enabled, the server downloads the IP to Country database on first use
# and refreshes it monthly. Disable it to use only a database file placed
# manually in DEDALOGEOIPDIR (e.g. air-gapped installs).
# [operator · bool]  default: true
#DEDALO_GEOIP_AUTO_UPDATE=true

# Overrides the default monthly DB-IP download URL. Use it to point at a
# mirror or a pinned month. The default is
# https://download.db-ip.com/free/dbip-country-lite-YYYY-MM.mmdb.gz (the
# current month, with a fallback to the previous month), computed
# automatically.
# [operator · string]  default: (unset)
#DEDALO_GEOIP_DB_URL=

# ══════════════════════════════════════════════════════════════════════════════
#  [diffusion]  Diffusion variables
# ══════════════════════════════════════════════════════════════════════════════

# The number of records the publication resolver walks per batch. Diffusion is
# a streaming process: records are selected in ordered batches, resolved, and
# handed to the format writer, so that a section of hundreds of thousands of
# records never has to fit in memory at once. A smaller batch lowers the
# memory ceiling of a publication run; a larger one reduces the number of
# round trips to the database.
# [operator · int]  default: (unset)
#DEDALO_DIFFUSION_BATCH_RECORDS=

# The maximum number of rows the engine packs into a single insert/update
# statement when it writes a published table into the target database. Default
# 200.
# [operator · int]  default: 200
#DEDALO_DIFFUSION_BATCH_ROWS=200

# This parameter would be set with the diffusion domain of our project
# publication, diffusion domain is the target domain or the part of diffusion
# ontology that will be used to get the tables and fields and the relation
# components in the back-end.
# [operator · string]  default: (unset)
#DEDALO_DIFFUSION_DOMAIN=

# The directory under which the file-format publications (RDF, XML, Markdown,
# CSV, JSON…) are written, one subdirectory per publication target. When unset
# — the normal case — Dédalo publishes under MEDIAPATH, the same root the
# media files live in, so that publishing and un-publishing (which removes the
# files of a deleted record) always agree on where the artifacts are.
# [operator · string]  default: (unset)
#DEDALO_DIFFUSION_FILES_ROOT=

# How many publication jobs may run at the same time. Dédalo queues every
# diffusion request durably and dispatches it to a runner process of its own —
# a separate, killable process with its own memory ceiling — so a long
# publication survives a browser disconnect, a logout, or a server restart.
# This key caps how many of those processes the scheduler will have in flight;
# further jobs simply wait in the queue. Default 2, minimum 1.
# [operator · int]  default: 2
#DEDALO_DIFFUSION_MAX_RUNNERS=2

# Routes the publication tool to the diffusion engine built into this server
# instead of the separate, external diffusion service of earlier releases. Set
# to true once the installation's publications have been validated against the
# native engine: the tool in the browser is unchanged, only the server that
# answers it is.
# [operator · bool]  default: false
#DEDALO_DIFFUSION_NATIVE=false

# A staged-migration lever: a comma-separated list of the diffusion element
# tipos that the native engine is allowed to publish, or all for every one of
# them. An element outside the list is refused loudly with an explicit "not
# routed" message, so that one element+section is never published by two
# engines at once.
# [operator · string]  default: (unset)
#DEDALO_DIFFUSION_NATIVE_ELEMENTS=

# This parameter set the number of resolution levels we would like to
# accomplish. By default, its value is set to '2'.
# [operator · int]  default: 2
#DEDALO_DIFFUSION_RESOLVE_LEVELS=2

# Whether this server claims publication jobs from the queue and dispatches
# runner processes for them. Enabled by default: a standard, single-server
# installation must have it on, or publications will queue and never start.
# [operator · bool]  default: true
#DEDALO_DIFFUSION_SCHEDULER_ENABLED=true

# ══════════════════════════════════════════════════════════════════════════════
#  [db]  Work system database variables
# ══════════════════════════════════════════════════════════════════════════════

# This parameter defines the hostname of the server that is running the
# database. By default Dédalo uses localhost, because the database and the web
# server typically run on the same machine — but it is possible to point this
# at a separate database server.
# [operator · string]  default: localhost
DB_HOST=localhost

# This parameter defines the name of the database in PostgreSQL.
# [operator · string]  default: dedalo_install_placeholder
DB_NAME=dedalo_mydatabase

# This parameter defines the password of the database user.
# [secret · string]  default: (empty)
DB_PASSWORD=mypassword

# How long (in milliseconds) a request waits for a free database connection
# when the pool is fully in use, before it gives up with an error. The default
# 0 means wait forever.
# [operator · int]  default: 0
#DB_POOL_ACQUIRE_TIMEOUT_MS=0

# The maximum number of PostgreSQL connections this process keeps open.
# Default 10, minimum 1.
# [operator · int]  default: 10
#DB_POOL_MAX=10

# This parameter defines the host port of the server that is running the
# database. By default Dédalo uses the default PostgreSQL 5432 port.
# [operator · int]  default: 5432
#DB_PORT=5432

# The maximum time (in milliseconds) any single database statement may run
# before PostgreSQL cancels it. The default 0 means no limit.
# [operator · int]  default: 0
#DB_STATEMENT_TIMEOUT_MS=0

# This parameter defines the name of the user who can administer the database.
# This user must be an administrator or owner of the database, Dédalo must be
# able to create, update and select all tables and records.
# [operator · string]  default: dedalo
DB_USER=myusername

# This parameter defines the directory holding the PostgreSQL client binaries
# (psql, pgdump, pgrestore) used for maintenance tasks and backups. When
# unset, Dédalo probes common Homebrew install locations (newest version
# first) and falls back to resolving the binary name from PATH.
# [operator · string]  default: (unset)
#DEDALO_PG_BIN_PATH=

# From this list offset on, default-ordered section searches are rewritten to
# a "late row lookup": the wanted page of record ids is found on an index-only
# scan first, and only those rows' full data is fetched. Same rows, same order
# — measured ~70× faster at offset 300000 on a 438k-record section, because a
# plain OFFSET makes PostgreSQL read and discard every skipped row's data
# columns.
# [operator · int]  default: 1000
#SEARCH_LATE_ROW_LOOKUP_OFFSET=1000

# The unfiltered time-machine browse shows a total that costs a full count of
# the (typically huge, append-only) matrixtimemachine table. That total is
# cached and invalidated on every save this engine performs; this key is the
# freshness backstop (in milliseconds) for rows inserted by anything else.
# Default 30000 (30 s). Set 0 to disable the cache and count exactly on every
# request — the right setting for parity test environments.
# [operator · int]  default: 30000
#TM_COUNT_CACHE_TTL_MS=30000

# This parameter defines the time limit for query calls: if a query takes
# longer than this value, Dédalo logs a warning line naming the slow
# statement. Set to 0 (the default) to disable slow-query logging.
# [operator · int]  default: 0
#DEDALO_SLOW_QUERY_MS=0

# ══════════════════════════════════════════════════════════════════════════════
#  [diffusion_db]  Diffusion system database (MariaDB)
# The diffusion system database is the external, flat (publication) copy of
# the data, stored in MariaDB/MySQL: only public data is exported,
# relationships are pre-resolved, and the result is standard SQL
# tables/rows/columns.

Every MariaDB operation — publish, delete, backup — is
# performed by the [diffusion engine](../diffusion/native_engine.md) built
# into the work server.
# ══════════════════════════════════════════════════════════════════════════════

# The hostname or IP of the MariaDB/MySQL server that receives the published
# tables. Set it when the publication target runs on a different machine than
# Dédalo, or when it listens on TCP rather than on a local socket.
# [operator · string]  default: (unset)
#DEDALO_DIFFUSION_DB_HOST=

# The password of DEDALODIFFUSIONDBUSER, the account Dédalo uses to write the
# published tables into the target database. This is a secret: the shipped
# template carries a placeholder only, and a real installation must replace it
# with the actual password (or leave it empty when the target authenticates
# the user by socket instead).
# [secret · string]  default: (empty)
#DEDALO_DIFFUSION_DB_PASSWORD=

# The TCP port of the publication target database. Only used when
# DEDALODIFFUSIONDBHOST is set (a socket connection ignores it). Defaults to
# 3306, the standard MariaDB/MySQL port.
# [operator · int]  default: 3306
#DEDALO_DIFFUSION_DB_PORT=3306

# Path to the local unix socket of the publication target database. Set it
# when the target server runs on the same machine as Dédalo and you want to
# bypass TCP — the usual production posture, and the fastest one.
# [operator · string]  default: (unset)
#DEDALO_DIFFUSION_DB_SOCKET=

# The user account Dédalo connects with to publish into the target database.
# It must be able to create and alter the published tables and to insert,
# update and delete their rows: the engine provisions the table structure from
# the diffusion ontology on every run, so read/write on existing tables is not
# enough.
# [operator · string]  default: (empty)
#DEDALO_DIFFUSION_DB_USER=

