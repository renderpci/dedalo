{
	"name": "dedalo-server-ts",
	"description": "Dédalo server — greenfield native TypeScript rewrite on Bun. Spec: engineering/REWRITE_SPEC.md",
	"version": "0.0.1",
	"module": "src/server.ts",
	"type": "module",
	"private": true,
	"engines": {
		"bun": "1.3.9"
	},
	"scripts": {
		"start": "bun run src/server.ts",
		"start:supervised": "while true; do bun run src/server.ts; code=$?; [ $code -eq 75 ] || exit $code; echo '[supervisor] restart requested (exit 75) — rebooting into the persisted config'; done",
		"dev": "while true; do bun run --watch src/server.ts; code=$?; [ $code -eq 75 ] || exit $code; echo '[supervisor] restart requested (exit 75) — rebooting into the persisted config'; done",
		"dedalo:install": "bun run scripts/install.ts",
		"dedalo:migrate-config": "bun run scripts/migrate_v6_config.ts",
		"dedalo:migrate-passwords": "bun run scripts/migrate_v6_passwords.ts",
		"test": "bun test",
		"test:client": "bun run scripts/client_test_runner.ts",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.109.1",
		"@geoman-io/leaflet-geoman-free": "2.19.3",
		"@highlightjs/cdn-assets": "11.9.0",
		"@jaames/iro": "5.5.2",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@svgedit/svgcanvas": "7.4.2",
		"@turf/turf": "7.0.0",
		"codex-tooltip": "1.0.5",
		"d3": "7.9.0",
		"dropzone": "5.9.3",
		"flatpickr": "4.6.3",
		"leaflet": "1.9.4",
		"split.js": "1.6.5",
		"three": "0.149.0",
		"vanilla-jsoneditor": "3.12.0",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
		"zod": "^3.24.0",
		"zod-to-json-schema": "^3.25.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "latest",
		"chai": "4.3.8",
		"mocha": "11.1.0",
		"puppeteer": "^25.3.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
