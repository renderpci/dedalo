{
	"name": "dedalo-server-ts",
	"description": "Dédalo server — greenfield native TypeScript rewrite on Bun. Spec: engineering/REWRITE_SPEC.md",
	"version": "0.0.1",
	"module": "src/server.ts",
	"type": "module",
	"private": true,
	"engines": {
		"bun": "1.3.9"
	},
	"scripts": {
		"start": "bun run src/server.ts",
		"dev": "bun run --watch src/server.ts",
		"dedalo:install": "bun run scripts/install.ts",
		"dedalo:migrate-config": "bun run scripts/migrate_v6_config.ts",
		"dedalo:migrate-passwords": "bun run scripts/migrate_v6_passwords.ts",
		"test": "bun test",
		"test:client": "bun run scripts/client_test_runner.ts",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.109.1",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^3.24.0",
		"zod-to-json-schema": "^3.25.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "latest",
		"puppeteer": "^25.3.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
