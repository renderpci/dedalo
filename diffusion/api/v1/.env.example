# Bun Server (unix socket for Apache ProxyPass)
SOCKET_PATH=/tmp/diffusion.sock

# PHP Dédalo API
DEDALO_API_URL=http://localhost:8080/dedalo/core/api/v1/json/

# MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=web_dedalo

# Redis (shared session)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PREFIX=PHPREDIS_SESSION:
