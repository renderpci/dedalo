# Bun Server (unix socket for Apache ProxyPass)
SOCKET_PATH=/tmp/diffusion.sock

# PHP Dédalo API
DEDALO_API_URL=http://localhost:8080/dedalo/core/api/v1/json/

# Internal token for server-to-server actions (delete_record) without a session
# (CLI/cron retry). Must match DEDALO_DIFFUSION_INTERNAL_TOKEN in the PHP config.
# Leave empty to disable the token auth path entirely.
DIFFUSION_INTERNAL_TOKEN=

# MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=web_dedalo

# mysqldump binary used by the backup_database action (default: mysqldump in PATH)
MYSQLDUMP_BIN=


