# Optional overrides for `bun test` (Bun sets NODE_ENV=test and auto-loads .env.test).
#
# The integration suites (test/integration/) create and drop the dedicated
# database `web_test_diffusion`. The MariaDB user needs privileges on it:
#
#   GRANT ALL PRIVILEGES ON `web_test_diffusion`.* TO '<user>'@'localhost';
#   FLUSH PRIVILEGES;
#
# When MariaDB is unreachable OR the privilege is missing, the integration
# suites skip cleanly and `bun test` stays green.
#DB_SOCKET=/tmp/mysql.sock
# CI / remote MariaDB over TCP (used only when DB_SOCKET is unset):
#DB_FORCE_TCP=1
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_USER=root
#DB_PASSWORD=
