# =============================================================================
# Dédalo — /private/.env template
# =============================================================================
# Copy this file to  /private/.env  (a directory OUTSIDE the web root, sibling
# of the install root — the same place sessions/ and backups/ already live) and
# fill in the real values for THIS deployment.
#
#   cp config/.env.dist ../private/.env      # adjust path to your /private dir
#
# This is the highest-priority configuration layer. Put here ONLY:
#   - secrets (DB passwords, salt, internal tokens), and
#   - the few non-secret values that differ from config/defaults.env.
# Everything you do not set falls through to defaults.env. Never commit /private.
#
# Precedence (last wins):
#   defaults.env < profiles/<name>.env < /private/.env < real environment vars
#
# Validate the declarative layer at any time with:
#   php config/bootstrap/dev/lint_config.php
# =============================================================================

# --- identity ----------------------------------------------------------------
# DEDALO_ENTITY=my_entity_name          # unique id, no spaces / non-ASCII
# DEDALO_ENTITY_ID=0
# DEVELOPMENT_SERVER=false

# --- secrets (REQUIRED for a real install; keep out of version control) -------
# Crypto salt — change from the sample default before installing.
# DEDALO_SALT_STRING=change_me_to_a_long_random_string
# Server-to-server diffusion token (must match diffusion/api/v1/.env).
# DEDALO_DIFFUSION_INTERNAL_TOKEN=

# DB secrets move here in Phase 2 (today still in config/config_db.php):
# DEDALO_DB_PASSWORD=...
# DEDALO_DB_USER=...
# MYSQL_DEDALO_PASSWORD_CONN=...

# --- common non-secret overrides (uncomment only what differs) ---------------
# DEDALO_MEDIA_ACCESS_MODE=publication        # false | private | publication
# DEDALO_DIFFUSION_DOMAIN=default
# DEDALO_PROJECTS_DEFAULT_LANGS=["lg-spa","lg-eng"]
