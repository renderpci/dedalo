# Protect files and directories from prying eyes.
# SEC-011: previous FilesMatch used a broken character class
# `[^config_client\.js|make_backup\.js]` and missed common sensitive files
# (.env, .git, lockfiles). Replaced with explicit, well-tested patterns.

# Block sensitive file extensions and editor temp files.
<FilesMatch "(?i)\.(inc|sh|txt|tpl|backup|test|sql|sql\.gz|sqlite|db|log|bak|old|orig|swp|swo|env|env\.example|lock|heapsnapshot|network-request)$">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order allow,deny
		Deny from all
	</IfModule>
</FilesMatch>

# Block PHP editor backup variants and emacs autosaves.
<FilesMatch "(\.php(~|\.sw[op]|\.orig|\.save|\.bak)$|^#.*#$|^\..*\.swp$)">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order allow,deny
		Deny from all
	</IfModule>
</FilesMatch>

# Block specific filenames (composer/bun/git/CI metadata).
<FilesMatch "^(composer\.json|composer\.lock|package\.json|package-lock\.json|bun\.lock|bun\.lockb|tsconfig\.json|\.gitignore|\.gitattributes|\.editorconfig|\.jshintrc|\.htaccess|\.htpasswd|cliff\.toml|phpstan\.neon\.dist|phpstan-bootstrap\.php|stub\.php|worker\.php|status\.md|AGENTS\.md|Updates\.md)$">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order allow,deny
		Deny from all
	</IfModule>
</FilesMatch>

# SEC-026 (§9.3): block direct HTTP access to `*_json.php` templates.
# These files are pure server-side INCLUDE targets used by `common::get_json()`
# (and a few peers like `relation_list::get_json()`). They expect to run inside
# the calling object's scope and use `$this` from the very first line; reaching
# them via HTTP produces a fatal error that:
#   * leaks file paths through the error message,
#   * skips the `dd_manager` CSRF + auth + opt-in `API_ACTIONS` allowlist
#     entirely, and
#   * exposes them as a future foothold if any maintainer ever adds a
#     side-effect (DB write, file IO) before the `$this` reference.
# No JS or HTML in the codebase fetches these files directly (verified), so a
# blanket deny is safe. nginx deployments must replicate this rule in their
# server config (e.g. `location ~ _json\.php$ { deny all; }`).
<FilesMatch "(?i)_json\.php$">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order allow,deny
		Deny from all
	</IfModule>
</FilesMatch>

# Block any dotfile (.env, .git, .DS_Store, etc.) at any path depth.
<FilesMatch "^\.">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order allow,deny
		Deny from all
	</IfModule>
</FilesMatch>

# Block sensitive directories from being served.
<IfModule mod_rewrite.c>
	RewriteEngine On
	# Allow browser-based client tests; block rest of test tree
	RewriteRule ^test/client(/|$) - [L]
	# SEC-089: added `code` to the denylist — the core/page code tree holds
	# source used by IS_A_CODE_SERVER deployments and should not be fetchable
	# from regular Dédalo installs. Code servers that need to expose it should
	# remove `code` from this list in a deployment-specific override.
	RewriteRule (^|/)(\.git|\.github|\.windsurf|\.agent|\.VSCodeCounter|node_modules|vendor|config|test|dev|install/db|install/http_modules|backup|backups|deleted|code)(/|$) - [F,L,NC]
</IfModule>

# SEC-088: block direct PHP / script execution under media, upload and tmp
# directories. Any file uploaded by a user lives under /media or /upload — if
# Apache's AddHandler matches `.php` there, a disguised-extension upload (or
# an upload whose server-side rewrite writes a `.php` artefact) would execute
# in the site origin. The rewrite rule below returns 403 for any attempt to
# fetch a script-extension file inside those roots. We intentionally DO NOT
# use a global `<FilesMatch>` + `SetHandler none` here because that would
# disable PHP for the whole site; the correct per-directory override lives
# in `media/.htaccess` / `upload/.htaccess` / `tmp/.htaccess` when the
# deployer creates those paths.
<IfModule mod_rewrite.c>
	RewriteEngine On
	# CONF-08: lib/ serves only client-side assets (js/css/images) and a few
	# server-side-only includes (lessphp, included by filesystem path). No PHP/script
	# under lib/ should ever be executed via a direct HTTP request — deny it (static
	# .js/.css/.png assets are unaffected).
	RewriteRule (^|/)(media|upload|tmp|lib)/.+\.(phps?|phtml|phar|pht|inc|cgi|pl|py|rb|sh|lua|asp|aspx|jsp)$ - [F,L,NC]
</IfModule>

# Browser caching FileETag control
# <FilesMatch ".+\.(js|css)$">
# 	# Set FileETag looking MTime and size to allow detect changes on js and css files
# 	# @see https://stackoverflow.com/questions/13215213/how-do-i-configure-etags
# 	FileETag All
# 	# FileETag INode,
# 	# FileETag MTime,
# 	# FileETag Size,
# 	# FileETag INode MTime,
# 	# FileETag INode Size or
# 	# FileETag MTime Size may also be set.
# 	# FileETag All
# 	# Remove ETag optional way
# 	# Header unset ETag
# 	# FileETag none
# 	# Header set Cache-Control "public, must-revalidate, max-age=3600"
# 	# Header unset ETag
# </filesMatch>

# Deny paths final and between
# RewriteEngine On
# RewriteRule (config) - [F,L]

# <FilesMatch ".(eot|ttf|otf|woff|woff2)">
#   Header set Access-Control-Allow-Origin "*"
# </FilesMatch>

# Don't show directory listings for URLs which map to a directory.
Options -Indexes

# Set the default handler.
<IfModule dir_module>
	DirectoryIndex index.html index.php
</IfModule>

# Ensure JavaScript files are served with correct MIME type for module scripts
<IfModule mime_module>
	AddType application/javascript .js
	AddType text/javascript .mjs
</IfModule>

# SEC-015: baseline security response headers.
# SEC-XSS-CSP (§7.x): Content-Security-Policy rolled out in Report-Only mode
# first. Deployers should collect reports for a release cycle, then flip the
# `Content-Security-Policy-Report-Only` line to `Content-Security-Policy` to
# enforce. Directives below reflect the audited resource graph:
#   * `'unsafe-eval'` is mandatory because vendored libraries (pdfjs,
#     jsoneditor, leaflet, d3, threejs, dropzone, vexflow) use `new Function`
#     or `eval` internally. Removing it requires replacing those libs.
#   * `'unsafe-inline'` on style-src is required because Dédalo sets inline
#     `style=` attributes extensively via `setAttribute('style', ...)`
#     (svgedit, component_pdf, tool_image_*). Nonce-based styles would need
#     a full refactor.
#   * `data:` and `blob:` are needed for dynamically generated images,
#     media previews, and worker scripts (pdfjs worker, audio blobs).
#   * `img-src` allows the external map tile hosts used by
#     component_geolocation (Leaflet): OpenStreetMap (`*.tile.openstreetmap.org`,
#     `*.tile.osm.org`), CartoDB dark tiles (`*.basemaps.cartocdn.com`),
#     ArcGIS World Imagery (`server.arcgisonline.com`) and
#     the DARE/Imperium historical tileset (`dh.gu.se`). Listed without scheme
#     so they match on both http (dev) and https (prod) pages.
#   * `object-src 'none'` blocks Flash/plugin embeds.
#   * `base-uri 'self'` + `form-action 'self'` prevent <base> hijacking and
#     cross-origin form posts.
#   * `frame-ancestors 'self'` mirrors the X-Frame-Options SAMEORIGIN policy
#     (CSP supersedes X-Frame-Options on modern browsers).
# NOTE: the `report-uri` directive is left off by default because no report
# collector ships with Dédalo. Deployers that run a CSP report endpoint
# should append `report-uri /csp-report` (or `report-to` with a Report-To
# header) before enforcing.
<IfModule mod_headers.c>
	Header always set X-Content-Type-Options "nosniff"
	Header always set X-Frame-Options "SAMEORIGIN"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	Header always set Permissions-Policy "geolocation=(self), microphone=(), camera=()"
	# HSTS: only meaningful over HTTPS; harmless when the site is HTTP because
	# browsers ignore it on plain HTTP, but enable behind TLS termination.
	Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
	# Strip the Proxy request header (CVE-2016-5385 / httpoxy).
	RequestHeader unset Proxy

	# Content Security Policy (enforced).
	Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' blob: 'sha256-tGMkWyBVqSrhE1glBFdD2I51om9BJkjuXVKgevMfXS4='; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: *.tile.openstreetmap.org *.tile.osm.org *.basemaps.cartocdn.com server.arcgisonline.com dh.gu.se; media-src 'self' blob:; font-src 'self' data:; connect-src 'self' blob: http://127.0.0.1:* http://localhost:*; frame-src 'self' blob:; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"

	# Report-Only version (for monitoring — swap with enforced line above if needed):
	# Header always set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-eval' blob: 'sha256-tGMkWyBVqSrhE1glBFdD2I51om9BJkjuXVKgevMfXS4='; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: *.tile.openstreetmap.org *.tile.osm.org *.basemaps.cartocdn.com server.arcgisonline.com dh.gu.se; media-src 'self' blob:; font-src 'self' data:; connect-src 'self' blob: http://127.0.0.1:* http://localhost:*; frame-src 'self' blob:; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
</IfModule>

# Legacy header section preserved (commented) for reference.
# <IfModule mod_headers.c>
	# Disable content sniffing, since it's an attack vector.
	# Header always set X-Content-Type-Options nosniff
	# Disable Proxy header, since it's an attack vector.
	# RequestHeader unset Proxy

  # PRODUCTION
  # Set cache files for one week 3600 * 24 * 7 = 604800
  # Header set Cache-Control: stale-while-revalidate=604800

  # DEVELOPMENT
  # <If "%{HTTP_HOST} =~ /(127\.0\.0\.1.+|localhost.+)$/">
	#  Header set Cache-Control: "no-store, max-age=0"
	#  Header unset ETag
  # </If>
# </IfModule>

# re-direct old v5 paths to the new ones
<IfModule mod_rewrite.c>
	# str_manager
	RewriteRule ^lib/dedalo/extras/str_manager/$ core/extras/str_manager/ [NS,L]
</IfModule>
