    "dd612": {
      "inf": "Descripción [component_text_area]",
      "dato": {
        "lg-ara": [
          "<p>أداة لترجمة المحتوى إلى لغات أخرى</p>"
        ],
        "lg-cat": [
          "<p>Eina per traduir contingut a altres idiomes</p>"
        ],
        "lg-deu": [
          "<p>Tool zum Übersetzen des Inhalts in andere Sprachen</p>"
        ],
        "lg-ell": [
          "<p>Εργαλείο για τη μετάφραση του περιεχομένου σε άλλες γλώσσες</p>"
        ],
        "lg-eng": [
          "<p>Tool for translate the content to other languages</p>"
        ],
        "lg-eus": [
          "<p>Edukia beste hizkuntzetara itzultzeko tresna</p>"
        ],
        "lg-fra": [
          "<p>Outil pour traduire le contenu dans d'autres langues</p>"
        ],
        "lg-ita": [
          "<p>Strumento per tradurre i contenuti in altre lingue</p>"
        ],
        "lg-nep": [
          "<p>अन्य भाषाहरूमा सामग्री अनुवाद गर्न उपकरण</p>"
        ],
        "lg-por": [
          "<p>Ferramenta para traduzir conteúdos para outros idiomas.</p>"
        ],
