# Test environment — Bun loads this automatically under `bun test` (NODE_ENV=test).
# The filesystem roots point at a repo-local scratch dir the tests create and clean up.
SERVICE_TOKEN=test-service-token-000000000000000000000000
SITES_ROOT=./.test-tmp/workspaces
PREPROD_ROOT=./.test-tmp/preprod
PROD_ROOT=./.test-tmp/prod
PREPROD_BASE_URL=http://preprod.test
PROD_BASE_URL=http://prod.test
PUBLICATION_API_URL=http://publication.test/publication/server_api/v2
AGENT_DRIVER=claude_code
# Empty bins so driver detection reports unavailable in tests (no real CLIs installed).
CLAUDE_CODE_BIN=
OPENCODE_BIN=
PI_BIN=
MAX_SITES=5
