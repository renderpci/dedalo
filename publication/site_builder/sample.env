# Dédalo Site Builder — configuration template.
#
# Copy to .env (install.sh does this) and fill in. Every key is validated at boot; an
# invalid value exits the process rather than starting under a configuration nobody chose.
# LLM provider credentials live ONLY here — never in the engine, never in a site workspace.

# --- Serving ---
# apache | nginx | standalone. Loopback behind the proxy is the expected deployment.
DEPLOYMENT_MODE=nginx
PORT=3200
HOST=127.0.0.1
# The subpath the proxy mounts the daemon under; the router strips it before matching.
BASE_PATH=/publication/site_builder
# development | production | test. Production hides internal error detail.
NODE_ENV=production
LOG_LEVEL=info

# --- Auth (REQUIRED) ---
# Shared bearer token the engine presents on every call. Generate with:
#   openssl rand -hex 32
# Put the SAME value in the engine's ../private/.env as DEDALO_SITE_BUILDER_TOKEN.
SERVICE_TOKEN=

# --- Filesystem roots ---
# Distinct trees. Prod is a COPY of a build, so deleting a workspace never breaks a live site.
SITES_ROOT=/var/lib/dedalo_sites/workspaces
PREPROD_ROOT=/var/lib/dedalo_sites/preprod
PROD_ROOT=/var/www/dedalo_sites

# --- Public URLs (REQUIRED) ---
# Returned to the engine UI for preview/open links. Path-based by default; a site may get
# a custom domain the operator wires manually.
PREPROD_BASE_URL=https://preprod.example.org
PROD_BASE_URL=https://www.example.org

# --- Data source (REQUIRED) ---
# The read-only Publication API v2 the generated sites read, and the agent's MCP endpoint
# (<PUBLICATION_API_URL>/mcp). Point at the production published data.
PUBLICATION_API_URL=https://data.example.org/publication/server_api/v2
# Only if that v2 instance has API_KEYS configured (default: open, leave blank).
PUBLICATION_API_KEY=

# --- Agent drivers ---
# Default driver for new sites (a site may pin its own): claude_code | opencode | pi.
AGENT_DRIVER=claude_code
# Binary names or absolute paths. An empty *_BIN marks that driver unavailable.
CLAUDE_CODE_BIN=claude
OPENCODE_BIN=
PI_BIN=
# Provider credentials, forwarded ONLY to the matching driver's child process.
ANTHROPIC_API_KEY=
# Extra per-driver env as comma-separated KEY=VALUE (e.g. OPENAI_API_KEY=sk-...).
OPENCODE_ENV=
PI_ENV=

# --- Limits ---
MAX_SITES=20
MAX_CONCURRENT_SESSIONS=2
SESSION_TURN_TIMEOUT_MS=1200000
INSTALL_TIMEOUT_MS=300000
BUILD_TIMEOUT_MS=300000
SITE_DISK_QUOTA_MB=1024
RELEASES_RETAINED=5
