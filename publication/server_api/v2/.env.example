# Deployment
DEPLOYMENT_MODE=apache
PORT=3100
HOST=127.0.0.1
BASE_PATH=/publication/server_api/v2
TRUST_PROXY=true
NODE_ENV=production

# MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=readonly_user
DB_PASSWORD=secret
DB_NAME=dedalo_web
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_QUERY_TIMEOUT=5000

# Security
API_KEYS=
RATE_LIMIT_RPM=100
CORS_ORIGIN=*
MAX_BODY_SIZE=65536

# Media
MEDIA_BASE_URL=/dedalo/media

# MCP
MCP_ENABLED=true
MCP_PATH=/mcp

# Logging
LOG_LEVEL=info
