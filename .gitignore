# Dependencies
node_modules/

# OS noise
.DS_Store

# Never commit secrets (config lives in ../private/, outside the repo)
.env

# Client libraries: nothing to ignore, and that is the point. They come from
# `bun install` (node_modules/, already ignored above) or they are COMMITTED under
# vendor/ — ckeditor, json-view, pdfjs. There is no install-time fetch step and no
# generated lib directory, so a clone is self-contained.
# Index of record: src/core/client_libs/registry.ts.

# Agent tooling. `.agents/` is the real home (skills + workflows ARE versioned);
# `.claude` is a committed symlink alias to it, so Claude Code keeps working.
# Machine-local state below is never versioned. Git does not descend into the
# symlink, so these must name the REAL path — `.claude/...` rules would be dead.
.agents/settings.local.json
.agents/scheduled_tasks.lock

# Local-only foundation audits (security analysis etc.) — not version-controlled
audits/
.claude_migration_component_alias_preimage.json
rewrite/
